# Copia este archivo como ".env" y completa tus valores reales.
# El .env NO se sube al repositorio (está en .gitignore).

# --- Roboflow (inferencia hospedada) ---
# IMPORTANTE: regenera esta key en tu panel de Roboflow; la anterior quedó expuesta.
ROBOFLOW_API_KEY=tu_api_key_de_roboflow
ROBOFLOW_API_URL=https://serverless.roboflow.com

# --- WhatsApp vía Twilio ---
# Se obtienen en https://console.twilio.com (usa el Sandbox de WhatsApp para probar)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+51XXXXXXXXX

# --- Parámetros del sistema (opcionales) ---
CONF_THRESHOLD=0.40
COOLDOWN_SEGUNDOS=30
INTERVALO_INFERENCIA=1.0

# --- Modelos activos por defecto (opcional, separados por coma) ---
# MODELOS_ACTIVOS=armas,rostros,placas

# --- Modelos adicionales de Roboflow (FASE 3 - Prompt 11) ---
# Para añadir un modelo sin tocar el código, usa MODELO_<NOMBRE>=<model_id>
# Ejemplo:
# MODELO_CASCOS=hard-hat-workers-gkqmq/6

# --- Foto por WhatsApp (FASE 3 - Prompt 12, requiere --enviar-foto) ---
# URL base pública que sirve la carpeta capturas/
# Usar ngrok: ngrok http 8000 (con python -m http.server 8000 en raiz del proyecto)
# URL_PUBLICA_CAPTURAS=https://xxxx.ngrok-free.app/capturas




